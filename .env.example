# ── MAX Bot API ───────────────────────────────────────────────
# Токен бота из @MasterBot в MAX. Авторизация идёт БЕЗ префикса Bearer.
MAX_BOT_TOKEN=

# Юзернейм бота (без https://max.ru/ и без @) — для построения deep-link.
# Можно оставить пустым: подтянется автоматически из GET /me при старте.
BOT_USERNAME=

# ── Хранилище ────────────────────────────────────────────────
# Путь к файлу SQLite. По умолчанию — clubromance.db рядом с проектом.
DB_PATH=clubromance.db

# ── Webhook-режим (только прод; для локального запуска не нужен) ──
# Публичный HTTPS-URL, по которому MAX будет слать апдейты.
WEBHOOK_BASE_URL=
# Секрет в пути вебхука: /webhook/<secret>. Сгенерируй случайную строку.
WEBHOOK_SECRET=
# Хост/порт, на которых поднимается FastAPI (за nginx).
WEBHOOK_HOST=127.0.0.1
WEBHOOK_PORT=8080

# ── Веб-админка (картинки + каналы ОП) ───────────────────────
# Логин/пароль для входа в админку (HTTP Basic). ADMIN_PASSWORD обязателен.
ADMIN_USER=admin
ADMIN_PASSWORD=
ADMIN_HOST=0.0.0.0
ADMIN_PORT=8080

# id админов через запятую (команда /give, байпас обязательной подписки).
ADMIN_IDS=

# ── Прочее ───────────────────────────────────────────────────
# Уровень логирования: DEBUG / INFO / WARNING
LOG_LEVEL=INFO
